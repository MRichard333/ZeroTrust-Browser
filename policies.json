{
  "policies": {

    "ExtensionSettings": {
      "*": {
        "installation_mode": "blocked",
        "blocked_install_message": "Only ZeroTrust-approved extensions are allowed.",
        "install_sources": [
          "https://addons.mozilla.org/*",
          "file:///*"
        ]
      },
      "uBlock0@raymondhill.net": {
        "installation_mode": "force_installed",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi"
      },
      "zerotrust@mrichard333.com": {
        "installation_mode": "force_installed",
        "install_url": "https://addons.mozilla.org/firefox/downloads/file/4730187/zerotrust_dashboard_extension-2.1.0.xpi"
      }
    },

    "Homepage": {
      "URL": "https://mrichard333.com/webtools|https://mrichard333.com/dashboard|https://mrichard333.com/link-scanner",
      "Locked": false,
      "StartPage": "homepage"
    },

    "NewTabPage": false,

    "DisplayBookmarksToolbar": "never",
    "DisablePocket": true,
    "DisableTelemetry": true,
    "DisableFirefoxStudies": true,
    "DisableFeedbackCommands": true,
    "DisableFormHistory": false,
    "DontCheckDefaultBrowser": true,

    "Permissions": {
      "Autoplay": {
        "Default": "block-audio"
      }
    },

    "UserMessaging": {
      "WhatsNew": false,
      "ExtensionRecommendations": false,
      "FeatureRecommendations": false,
      "UrlbarInterventions": false,
      "SkipOnboarding": true,
      "MoreFromMozilla": false
    },

    "FirefoxHome": {
      "Search": false,
      "TopSites": false,
      "SponsoredTopSites": false,
      "Highlights": false,
      "Pocket": false,
      "SponsoredPocket": false,
      "Snippets": false,
      "Locked": false
    },

    "SearchBar": "unified",

    "DNSOverHTTPS": {
      "Enabled": true,
      "ProviderURL": "https://cloudflare-dns.com/dns-query",
      "Locked": false
    },

    "HttpsOnlyMode": "force_enabled",

    "SSLVersionMin": "tls1.2",

    "EnableTrackingProtection": {
      "Value": true,
      "Locked": false,
      "Cryptomining": true,
      "Fingerprinting": true
    },

    "EncryptedMediaExtensions": {
      "Enabled": true,
      "Locked": false
    },

    "PopupBlocking": {
      "Default": true
    },

    "Cookies": {
      "Behavior": "reject-tracker-and-partition-foreign",
      "BehaviorPrivateBrowsing": "reject-tracker-and-partition-foreign"
    },

    "PasswordManagerEnabled": true,

    "AppUpdateURL": "https://aus5.mozilla.org/update/6/%PRODUCT%/%VERSION%/%BUILD_ID%/%BUILD_TARGET%/%LOCALE%/%CHANNEL%/%OS_VERSION%/%DISTRIBUTION%/%DISTRIBUTION_VERSION%/update.xml"

  }
}